{
  "ConnectionStrings": {
    "TradeFlow": "Host=localhost;Database=tradeflow;Username=tradeflow_user;Password=tradeflow_dev"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Update": "Warning",
        "System": "Warning",
        "Polly": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tradeflow-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "XTrades": {
    "PageSize": 50,
    "DateSpec": "Today",
    "OrderBy": "TimeOfEntryAlertEpoch desc"
  },
  "RiskEngine": {
    "TradingPaused": false,
    "MinXScore": 75,
    "MinStockPriceDollars": 3.00,
    "ApprovedTraders": [
      "Hydra"
    ],
    "RestrictedTraders": {
      "Sean@BearishBull": 25
    },
    "AllowLotto": true,
    "AllowHigh": true,
    "SkipTradeOnSlippageTimeout": true,
    "MaxDailyExposurePct": 30.0,
    "MarginPct": 0.0,
    "MaxEntrySlippagePct": 5.0,
    "MaxPositionsPerSymbol": 2,
    "OptionsInitialBudget": 2000,
    "OptionsAverageBudget": 1000,
    "OptionsLottoBudget": 1000,
    "OptionsLottoAverageBudget": 500,
    "OptionsStandardTrailPct": 20.0,
    "OptionsHighTrailPct": 30.0,
    "OptionsLottoTrailPct": 40.0,
    "OptionsTargetMultiple": 3.0,
    "OptionCloseThresholdPct": 50.0,
    "OptionPartialCloseRatio": 0.5,
    "StockInitialBudget": 1500,
    "StockAverageBudget": 500,
    "StockDailyAllocationPct": 40.0,
    "StockTargetMultiple": 2.0,
    "StockStandardTrailPct": 10.0,
    "StockHighTrailPct": 15.0,
    "StockLottoTrailPct": 20.0,
    "ZeroDteEntryCutoffHour": 12,
    "SameDayExpiryAutoCloseCutoff": "15:30",
    "BlockedSymbols": ["SPX", "NDX", "RUT", "VIX", "DJX", "NQ", "ES", "MES", "MNQ", "YM", "RTY"]
  },
  "Polling": {
    "IntervalSeconds": 30
  },
  "Trades": {
    "Directory": "../../../../trades",
    "ArchiveDirectory": "../../../../trades/archive"
  },
  "Ibkr": {
    "Host": "127.0.0.1",
    "Port": 4002,
    "ClientId": 1,
    "AccountId": "",
    "TimeoutMs": 15000
  },
  "Analytics": {
    "ReportsDirectory": "../../../../reports"
  }
}