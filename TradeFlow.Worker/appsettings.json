{
  "ConnectionStrings": {
    "TradeFlow": "Host=localhost;Database=tradeflow;Username=tradeflow_user;Password=tradeflow_dev"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Update": "Warning",
        "System": "Warning",
        "Polly": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tradeflow-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "XTrades": {
    "PageSize": 50,
    "DateSpec": "Today",
    "OrderBy": "TimeOfEntryAlertEpoch desc"
  },
  "RiskEngine": {
    "TradingPaused": false,
    "MinXScore": 60,
    "MinStockPriceDollars": 3.00,
    "ApprovedTraders": [
      "Fibonaccizer",
      "ryan-21k",
      "HelmeHU",
      "Buzo"
    ],
    "RestrictedTraders": {
      "Tim" : 0
    },
    "AllowedDiscordRanks": [
      "Top Analyst",
      "Analyst",
      "Junior Analyst",
      "Top Trader",
      "XT Sniper"
    ],
    "AllowLotto": true,
    "AllowHigh": true,
    "SkipTradeOnSlippageTimeout": false,
    "MaxDailyExposurePct": 100.0,
    "MarginPct": 0.0,
    "MaxEntrySlippagePct": 5.0,
    "MaxPositionsPerSymbol": 1,
    "OptionsInitialBudget": 3000,
    "OptionsAverageBudget": 1500,
    "OptionsLottoBudget": 500,
    "OptionsLottoAverageBudget": 500,
    "OptionsStandardTrailPct": 40.0,
    "OptionsHighTrailPct": 50.0,
    "OptionsLottoTrailPct": 60.0,
    "OptionsTargetMultiple": 3.0,
    "OptionCloseThresholdPct": 50.0,
    "OptionPartialCloseRatio": 0.5,
    "StockInitialBudget": 3000,
    "StockAverageBudget": 1500,
    "StockDailyAllocationPct": 40.0,
    "StockTargetMultiple": 2.0,
    "StockStandardTrailPct": 10.0,
    "StockHighTrailPct": 15.0,
    "StockLottoTrailPct": 20.0,
    "ZeroDteEntryCutoffHour": 12,
    "SameDayExpiryAutoCloseCutoff": "15:30",
    "BlockedSymbols": ["SPX","NDX","RUT","VIX","DJX","NQ","ES","MES","MNQ","YM","RTY",
                      "NVDL","TSLL","TQQQ","SQQQ","SPXL","SPXS","SOXL","SOXS","UVXY"],
    "DailyLossLimit": -30000,
    "PostFillMaxSlippagePct": 7.0,
    "ChopVixSpikePct": 3.0,
    "ChopAdxThreshold": 20.0,
    "ChopSpyExtendedPct": 7.0,
    "ChopVixLevel": 20.0,
    "ChopMinSignals": 2,
    "ChopDailyLossLimit": -20000,
    "RegimeBullishSizingPct": 1.0,
    "RegimeChoppySizingPct": 0.5,
    "RegimeBearishSizingPct": 0.25,
    "RegimeBearishBlockCalls": true,
    "RegimeVixBearishThreshold": 20.0,
    "RegimeVixChoppyThreshold": 18.0,
    "RegimeSpyBelow50MaPct": 0.0
  },
  "Polling": {
    "IntervalSeconds": 30
  },
  "Trades": {
    "Directory": "../../../../trades",
    "ArchiveDirectory": "../../../../trades/archive"
  },
  "Ibkr": {
    "Host": "127.0.0.1",
    "Port": 4002,
    "ClientId": 1,
    "AccountId": "",
    "TimeoutMs": 15000
  },
  "Analytics": {
    "ReportsDirectory": "../../../../reports"
  }
}