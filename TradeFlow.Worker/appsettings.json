{
  "ConnectionStrings": {
    "TradeFlow": "Host=localhost;Database=tradeflow;Username=tradeflow_user;Password=tradeflow_dev"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Update": "Warning",
        "System": "Warning",
        "Polly": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tradeflow-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "XTrades": {
    "PageSize": 10,
    "DateSpec": "Today",
    "OrderBy": "TimeOfEntryAlertEpoch desc"
  },
  "RiskEngine": {
    "MinXScore": 60,
    "MinStockPriceDollars": 3.00,
    "ApprovedTraders": [
      "Theo",
      "bahamut2785",
      "alexander_xt",
      "Aspentrade1703",
      "KrazyA - [$TSLA 👶 🐐]",
      "Draw the Lamp",
      "ScottAlerts",
      "Firestarter",
      "$$$ Mr Bottom Bouncer $$$",
      "yoyomun",
      "Fibonaccizer",
      "Atlas",
      "SLAM",
      "Hydra",
      "OTC"
    ],
    "AllowLotto": true,
    "AllowHigh": true,
    "SkipTradeOnSlippageTimeout": true,
    "MaxEntrySlippagePct": 5.0,
    "OptionsStandardTrailPct": 40.0,
    "OptionsHighTrailPct": 50.0,
    "OptionsLottoTrailPct": 50.0,
    "StockStandardTrailPct": 10.0,
    "StockHighTrailPct": 15.0,
    "StockLottoTrailPct": 20.0,
    "ZeroDteEntryCutoffHour": 12,
    "SameDayExpiryAutoCloseCutoff": "15:30",
    "BlockedSymbols": ["SPX", "NDX", "RUT", "VIX", "DJX"]
  },
  "Polling": {
    "IntervalSeconds": 30
  },
  "Trades": {
    "Directory": "../../../../trades"
  },
  "Ibkr": {
    "Host": "127.0.0.1",
    "Port": 4002,
    "ClientId": 1,
    "AccountId": "",
    "TimeoutMs": 15000
  },
  "Analytics": {
    "ReportsDirectory": "../../../../reports"
  }
}