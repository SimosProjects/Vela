{
  "ConnectionStrings": {
    "TradeFlow": "Host=localhost;Database=tradeflow;Username=tradeflow_user;Password=tradeflow_dev"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Update": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tradeflow-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "XTrades": {
    "PageSize": 10,
    "DateSpec": "Today",
    "OrderBy": "TimeOfEntryAlertEpoch desc"
  },
  "RiskEngine": {
    "MinXScore": 70,
    "MinStockPriceDollars": 3.00,
    "ApprovedTraders": [
      "Theo",
      "bahamut2785",
      "alexander_xt",
      "Aspentrade1703",
      "KrazyA - [$TSLA 👶 🐐]",
      "Draw the Lamp",
      "ScottAlerts",
      "Firestarter",
      "$$$ Mr Bottom Bouncer $$$",
      "yoyomun",
      "Fibonaccizer",
      "Atlas",
      "SLAM"
    ],
    "AllowLotto": false
  },
  "Polling": {
    "IntervalSeconds": 30
  },
  "Trades": {
    "Directory": "../../../../trades"
  },
  "Ibkr": {
    "Host": "127.0.0.1",
    "Port": 4002,
    "ClientId": 1,
    "AccountId": "",
    "TimeoutMs": 5000
  },
  "Analytics": {
    "ReportsDirectory": "../../../../reports"
  }
}